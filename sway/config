# ------------- Variables
set $mainMod Mod4
set $corneMod Ctrl
set $terminal kitty
set $fileManager nemo

# ------------- Monitors
# Maps directly to your Hyprland preffered positions and sunshine headless profile
output eDP-1 pos 0 0 res 1920x1080
output HDMI-A-1 pos 1920 0 res 1920x1080

workspace 1 monitor eDP-1

# ------------- Autostart
# Fixed order to prevent D-Bus and portal timeouts
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec --no-startup-id sh -c 'eval $(gnome-keyring-daemon --login) eval $(gnome-keyring-daemon --start --components=secrets,ssh) export SSH_AUTH_SOCK'
exec nm-applet
exec waybar

# Set retro-cursor parameters
exec_always swaymsg seat seat0 xcursor_theme retro-cursor 24

# Wallpapers matching hyprpaper active target
exec_always swaybg -i ~/Pictures/wallpapers/odyssey.jpg -m fill

# Autotiling 
exec_always ~/.local/bin/autotiling

# ------------- Keybinds
# Basic Apps
bindsym $mainMod+f exec firefox
bindsym $mainMod+Return exec $terminal
bindsym $mainMod+e exec $fileManager
bindsym $mainMod+d exec wofi --show drun
bindsym $mainMod+q kill

# Lock screen replacement 
bindsym $mainMod+Shift+l exec hyprlock

# Floating / Fullscreen matching Hyprland layout rules
bindsym $mainMod+Shift+space floating toggle
bindsym $mainMod+Shift+f fullscreen toggle

# Screenshots
bindsym $mainMod+s exec ~/.local/bin/hyprshot --m region --clipboard-only
bindsym $mainMod+Shift+s exec grim -g "$(slurp)" "$(zenity --file-selection --save --confirm-overwrite --title='save screenshot WHEREE??' --filename='screenshot.png')"

# Laptop Multimedia keys mapped to scripts and systems
bindsym --locked XF86AudioRaiseVolume exec ~/.config/waybar/scripts/volume.sh output raise 2
bindsym --locked XF86AudioLowerVolume exec ~/.config/waybar/scripts/volume.sh output lower 2
bindsym --locked XF86AudioMute exec ~/.config/waybar/scripts/volume.sh output mute
bindsym --locked XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

bindsym --locked XF86MonBrightnessUp exec brightnessctl s 5%+
bindsym --locked XF86MonBrightnessDown exec brightnessctl s 5%-

bindsym --locked XF86AudioPlay exec playerctl play-pause
bindsym --locked XF86AudioStop exec playerctl stop
bindsym --locked XF86AudioPrev exec playerctl previous
bindsym --locked XF86AudioNext exec playerctl next

bindsym XF86Calculator exec qalculate-gtk

# Lid actions
bindswitch --locked lid:on exec hyprlock

# ------------- Workspaces
# Switch workspaces ($mainMod + [0-9])
bindsym $mainMod+1 workspace number 1
bindsym $mainMod+2 workspace number 2
bindsym $mainMod+3 workspace number 3
bindsym $mainMod+4 workspace number 4
bindsym $mainMod+5 workspace number 5
bindsym $mainMod+6 workspace number 6
bindsym $mainMod+7 workspace number 7
bindsym $mainMod+8 workspace number 8
bindsym $mainMod+9 workspace number 9
bindsym $mainMod+0 workspace number 10

# Move containers to workspaces silently via $corneMod (Ctrl)
bindsym $corneMod+1 move container to workspace number 1
bindsym $corneMod+2 move container to workspace number 2
bindsym $corneMod+3 move container to workspace number 3
bindsym $corneMod+4 move container to workspace number 4
bindsym $corneMod+5 move container to workspace number 5
bindsym $corneMod+6 move container to workspace number 6
bindsym $corneMod+7 move container to workspace number 7
bindsym $corneMod+8 move container to workspace number 8
bindsym $corneMod+9 move container to workspace number 9
bindsym $corneMod+0 move container to workspace number 10

# Move containers to workspaces silently via $mainMod + Shift
bindsym $mainMod+Shift+1 move container to workspace number 1
bindsym $mainMod+Shift+2 move container to workspace number 2
bindsym $mainMod+Shift+3 move container to workspace number 3
bindsym $mainMod+Shift+4 move container to workspace number 4
bindsym $mainMod+Shift+5 move container to workspace number 5
bindsym $mainMod+Shift+6 move container to workspace number 6
bindsym $mainMod+Shift+7 move container to workspace number 7
bindsym $mainMod+Shift+8 move container to workspace number 8
bindsym $mainMod+Shift+9 move container to workspace number 9
bindsym $mainMod+Shift+0 move container to workspace number 10

# ------------- Input Configuration
input * {
    xkb_layout "pl"
    natural_scroll disabled
}

# ------------- Mouse bindings for floating windows
floating_modifier $mainMod normal

# ------------- Design & Borders
# Matched to border_size = 2, gaps_in = 2, gaps_out = 4
gaps inner 2
gaps outer 4
default_border pixel 2
default_floating_border pixel 2

# Active and inactive color arrays mapped to your exact design layout
#                       border  bg      text    ind     child border
client.focused          #d8d8d8 #141216 #d8d8d8 #d8d8d8 #d8d8d8
client.focused_inactive #9b9b9b #141216 #d8cab8 #9b9b9b #9b9b9b
client.unfocused        #9b9b9b #141216 #d8cab8 #9b9b9b #9b9b9b
client.urgent           #fca002 #141216 #d8cab8 #fca002 #fca002

# ------------- Window Rules
# Ported directly from your exact floating size arrays and overrides
for_window [app_id="qalculate-gtk"]          floating enable, move position center, resize set 420 520
for_window [app_id="nemo"]                   floating enable, move position center, resize set 800 600
for_window [app_id="xdg-desktop-portal-gtk"] floating enable, move position center, resize set 800 600
for_window [app_id="org.gnome.FileRoller"]   floating enable, move position center, resize set 700 500
for_window [class="bluetui-popup"] floating enable, border pixel 2, resize set 700 450, move absolute position 610 40

# Unity popups minimum boundaries rules
for_window [class="Unity" title="Project Settings"] floating enable, resize set 250 250
for_window [class="Unity" title="Preferences"] floating enable, move position center, resize set 250 250
for_window [class="Unity" title="UnityEditor.AddComponent.AddComponentWindow"] floating enable, move position center, resize set 250 250
for_window [class="Unity" title="Package Manager"] floating enable, resize set 250 250
for_window [class="Unity" title="UI Toolkit Debugger"] floating enable, resize set 250 250
for_window [class="Unity" title="Font Asset Creator"] floating enable, resize set 250 500
for_window [class="Unity" title="Background Tasks"] floating enable, resize set 500 250
for_window [class="Unity" title="Color"] floating enable, move position center
for_window [class="Unity" title="HDR Color"] floating enable, move position center


include @sysconfdir@/sway/config.d/*


{
	"custom/fan": {
		"interval": 1,
		"format": " {}RPM",
		// "format-icons":
		"min-length": 7,
		"max-length": 7,
    "exec": "sensors | awk '/Fan 1:/ {val=$3} END {print (val ? val : '0')}'",
